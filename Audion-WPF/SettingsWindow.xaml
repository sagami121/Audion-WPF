<Window x:Class="Audion_WPF.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="430"
        Height="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Background="Transparent"
        Foreground="{DynamicResource TextMain}"
        Opacity="0"
        Loaded="Window_Loaded"
        MouseDown="Window_MouseDown">
    <Grid x:Name="OverlayRoot" Background="#30000000">
        <Border x:Name="CardBorder" Margin="4"
                Background="{DynamicResource SidebarBg}"
                CornerRadius="12"
                MouseDown="CardBorder_MouseDown"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform x:Name="CardScaleTransform" ScaleX="0.96" ScaleY="0.96" />
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,18">
                    <TextBlock x:Name="txtDialogTitle"
                               FontSize="18"
                               FontWeight="Bold"
                               VerticalAlignment="Center" />
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <Grid Margin="0,4,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="checkAlwaysOnTopLabel"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextDim}"
                                       VerticalAlignment="Center" />
                            <CheckBox x:Name="checkAlwaysOnTop"
                                      Grid.Column="1"
                                      Style="{StaticResource ModernCheckBoxStyle}" />
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="checkRestoreSessionLabel"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextDim}"
                                       VerticalAlignment="Center" />
                            <CheckBox x:Name="checkRestoreSession"
                                      Grid.Column="1"
                                      Style="{StaticResource ModernCheckBoxStyle}" />
                        </Grid>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="checkShowLyricsLabel"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextDim}"
                                       VerticalAlignment="Center" />
                            <CheckBox x:Name="checkShowLyrics"
                                      Grid.Column="1"
                                      Style="{StaticResource ModernCheckBoxStyle}" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,20" />

                        <TextBlock x:Name="txtThemeLabel"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Margin="0,0,0,12" />

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ToggleButton x:Name="btnThemeDark"
                                          Grid.Column="0"
                                          Height="46"
                                          Click="ThemeButton_Click"
                                          Tag="dark"
                                          Style="{StaticResource ThemeToggleButtonStyle}" />
                            <ToggleButton x:Name="btnThemeLight"
                                          Grid.Column="2"
                                          Height="46"
                                          Click="ThemeButton_Click"
                                          Tag="light"
                                          Style="{StaticResource ThemeToggleButtonStyle}" />
                        </Grid>

                        <TextBlock x:Name="txtLanguageLabel"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Margin="0,0,0,12" />

                        <ComboBox x:Name="comboLanguage"
                                  Height="44"
                                  Padding="14,0"
                                  Margin="0,0,0,20"
                                  SelectedValuePath="Tag"
                                  DisplayMemberPath="Content"
                                  Style="{StaticResource ModernComboBoxStyle}">
                            <ComboBoxItem Tag="ja" />
                            <ComboBoxItem Tag="en" />
                        </ComboBox>

                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,20" />

                        <Button x:Name="btnSave"
                                Height="46"
                                Margin="0,0,0,12"
                                Click="btnSave_Click"
                                Style="{StaticResource SettingsPrimaryButtonStyle}" />

                        <Button x:Name="btnFeedback"
                                Height="46"
                                Click="btnFeedback_Click"
                                Style="{StaticResource SettingsSecondaryButtonStyle}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           Text="&#xE946;"
                                           FontSize="14"
                                           Margin="0,0,8,0" />
                                <TextBlock x:Name="txtFeedbackButton" />
                            </StackPanel>
                        </Button>

                        <TextBlock x:Name="txtVersion"
                                   Margin="0,18,0,4"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextFaint}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
