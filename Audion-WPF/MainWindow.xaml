<Window x:Class="Audion_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Audion"
        Width="1000"
        Height="660"
        MinWidth="760"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{DynamicResource MainBg}"
        Foreground="{DynamicResource TextMain}"
        FontFamily="Segoe UI"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        Drop="Window_Drop">
    <Grid x:Name="RootLayout" Background="{DynamicResource MainBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="sidebarColumn" Width="340" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource SidebarBg}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="14,18,14,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnAddFiles"
                            Grid.Column="0"
                            Margin="0,0,6,0"
                            Height="46"
                            Click="btnFileSelect_Click"
                            Style="{StaticResource SidebarActionButtonStyle}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE8B7;"
                                       FontSize="15"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="txtAddFiles"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnAddFolder"
                            Grid.Column="1"
                            Margin="6,0,0,0"
                            Height="46"
                            Click="btnFolderSelect_Click"
                            Style="{StaticResource SidebarActionButtonStyle}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE8B7;"
                                       FontSize="15"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="txtAddFolder"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>

                <Grid Grid.Row="1" Margin="14,0,14,16">
                    <Border Background="{DynamicResource PanelAltBg}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE721;"
                                       FontSize="15"
                                       Foreground="{DynamicResource TextFaint}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                            <Grid Grid.Column="1">
                                <TextBox x:Name="searchBox"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0"
                                         Margin="0,0,12,0"
                                         TextChanged="searchBox_TextChanged"
                                         VerticalContentAlignment="Center" />
                                <TextBlock x:Name="txtSearchPlaceholder"
                                           Margin="0,0,12,0"
                                           Foreground="{DynamicResource TextFaint}"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text.Length, ElementName=searchBox}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="2" Margin="18,0,14,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="txtPlaylistHeader"
                               FontSize="12"
                               Foreground="{DynamicResource TextDim}"
                               VerticalAlignment="Center" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="btnSavePlaylist"
                                Width="30"
                                Height="30"
                                Margin="0,0,6,0"
                                Style="{StaticResource SmallIconButtonStyle}"
                                Click="btnSavePlaylist_Click">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE105;" FontSize="14" />
                        </Button>
                        <Button x:Name="btnLoadPlaylist"
                                Width="30"
                                Height="30"
                                Margin="0,0,6,0"
                                Style="{StaticResource SmallIconButtonStyle}"
                                Click="btnLoadPlaylist_Click">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE159;" FontSize="14" />
                        </Button>
                        <Border MinWidth="42"
                                Height="30"
                                Margin="0,0,6,0"
                                Padding="10,0"
                                CornerRadius="6"
                                Background="{DynamicResource PanelAltBg}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1">
                            <TextBlock x:Name="txtPlaylistCount"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextDim}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </Border>
                        <Button x:Name="btnClearPlaylist"
                                Width="30"
                                Height="30"
                                Style="{StaticResource DangerIconButtonStyle}"
                                Click="btnClearPlaylist_Click">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="3" Margin="14,0,14,14">
                    <Border x:Name="dropHint"
                            CornerRadius="10"
                            Background="{DynamicResource SidebarBg}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Padding="18"
                            Margin="0,0,0,8">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,30,0,30">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE898;"
                                       FontSize="38"
                                       Foreground="{DynamicResource Accent}"
                                       HorizontalAlignment="Center" />
                            <TextBlock x:Name="txtDropHintLine1"
                                       Margin="0,22,0,4"
                                       FontSize="16"
                                       Foreground="{DynamicResource TextDim}"
                                       HorizontalAlignment="Center" />
                            <TextBlock x:Name="txtDropHintLine2"
                                       FontSize="16"
                                       Foreground="{DynamicResource TextDim}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <ListBox x:Name="playlistList"
                             Background="Transparent"
                             BorderThickness="0"
                             SelectionChanged="playlistList_SelectionChanged"
                             MouseDoubleClick="playlistList_MouseDoubleClick"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Foreground="{DynamicResource TextMain}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,6" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd"
                                                    Background="{DynamicResource SidebarBg}"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="10,9">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PanelAltBg}" />
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PanelAltBg}" />
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="♪"
                                               Foreground="{DynamicResource Accent}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Title}"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextMain}" />
                                        <TextBlock Text="{Binding DisplaySubtitle}"
                                                   Margin="0,2,0,0"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextDim}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                               Margin="8,0,8,0"
                                               Text="{Binding Extension}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextDim}"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="3"
                                            Width="22"
                                            Height="22"
                                            Click="PlaylistItemDelete_Click"
                                            Style="{StaticResource DangerIconButtonStyle}"
                                            Tag="{Binding}">
                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" FontSize="11" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Border>

            <Grid Grid.Column="1" Background="{DynamicResource MainBg}" Margin="0,-22,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="1" Width="224" Height="224" HorizontalAlignment="Center" Margin="0,0,0,8">
                <Grid Width="208" Height="208" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid.RenderTransform>
                        <RotateTransform x:Name="AlbumArtRotateTransform" CenterX="104" CenterY="104" />
                    </Grid.RenderTransform>
                    <Ellipse x:Name="fallbackDisc" Fill="#4A4A4A" Width="208" Height="208" />
                    <Ellipse x:Name="albumArtEllipse" Width="208" Height="208" Visibility="Collapsed" />
                    <Ellipse Width="34"
                             Height="34"
                             Fill="Transparent"
                             Stroke="{DynamicResource Accent}"
                             StrokeThickness="2"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                    <Ellipse Width="8"
                             Height="8"
                             Fill="{DynamicResource Accent}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                    <TextBlock Text="&#x25B6;"
                               FontSize="11"
                               Foreground="{DynamicResource Accent}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="-11,-7,0,0" />
                </Grid>
            </Grid>

            <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,6,0,0" Width="390">
                <TextBlock x:Name="txtTrackName"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="txtArtistName"
                           Margin="0,6,0,0"
                           FontSize="13"
                           Foreground="{DynamicResource TextDim}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <Grid Grid.Row="3" Width="400" Margin="0,18,0,0" HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="txtCurrentTime"
                           Text="0:00"
                           FontSize="12"
                           Foreground="{DynamicResource TextDim}"
                           VerticalAlignment="Center" />

                <Slider Grid.Column="1"
                        x:Name="seekSlider"
                        Margin="28,0"
                        Minimum="0"
                        Maximum="1"
                        Style="{StaticResource TrackSliderStyle}"
                        PreviewMouseLeftButtonUp="seekSlider_PreviewMouseLeftButtonUp" />

                <TextBlock Grid.Column="2"
                           x:Name="txtTotalTime"
                           Text="0:00"
                           FontSize="12"
                           Foreground="{DynamicResource TextDim}"
                           VerticalAlignment="Center" />
            </Grid>

            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,22,0,0">
                <Button x:Name="btnShuffle" Width="38" Height="38" Margin="0,0,10,0" Style="{StaticResource ControlCircleButtonStyle}" Click="btnShuffle_Click">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE14B;" FontSize="14" />
                </Button>
                <Button x:Name="btnPrev" Width="48" Height="48" Margin="0,0,10,0" Click="btnPrev_Click" Style="{StaticResource ControlCircleButtonStyle}">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE892;" FontSize="18" />
                </Button>
                <Button x:Name="btnPlay" Width="64" Height="64" Margin="0,0,10,0" Click="btnPlay_Click" Style="{StaticResource PlayCircleButtonStyle}">
                    <TextBlock Text="&#x25B6;" FontSize="20" Margin="3,0,0,0" />
                </Button>
                <Button x:Name="btnNext" Width="48" Height="48" Margin="0,0,10,0" Click="btnNext_Click" Style="{StaticResource ControlCircleButtonStyle}">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE893;" FontSize="18" />
                </Button>
                <Button x:Name="btnRepeat" Width="38" Height="38" Margin="0,0,10,0" Style="{StaticResource ControlCircleButtonStyle}" Click="btnRepeat_Click">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE149;" FontSize="14" />
                </Button>
                <Button x:Name="btnSettings" Width="38" Height="38" Style="{StaticResource ControlCircleButtonStyle}" Click="btnSettings_Click">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="14" />
                </Button>
            </StackPanel>

            <StackPanel Grid.Row="5" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                    <Button x:Name="btnMute" Width="38" Height="38" Margin="0,0,12,0" Style="{StaticResource ControlCircleButtonStyle}" Click="btnMute_Click">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE15D;" FontSize="14" />
                    </Button>
                    <Slider x:Name="volumeSlider"
                            Width="180"
                            Maximum="100"
                            Value="80"
                            Style="{StaticResource WhiteSliderStyle}"
                            ValueChanged="volumeSlider_ValueChanged" />
                </StackPanel>

                <Border Width="228"
                        Height="30"
                        Background="{DynamicResource PanelAltBg}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="17">
                    <Grid Margin="10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="txtSpeedLabel"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextMain}"
                                   VerticalAlignment="Center" />
                        <Slider Grid.Column="1"
                                x:Name="speedSlider"
                                Margin="10,0,8,0"
                                Minimum="0.5"
                                Maximum="2"
                                TickFrequency="0.1"
                                SmallChange="0.1"
                                LargeChange="0.1"
                                Value="1"
                                Style="{StaticResource TrackSliderStyle}"
                                ValueChanged="speedSlider_ValueChanged" />
                        <TextBlock Grid.Column="2"
                                   x:Name="txtSpeed"
                                   Text="1.0x"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <TextBlock x:Name="txtVolume"
                           Text="80%"
                           Visibility="Collapsed" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
